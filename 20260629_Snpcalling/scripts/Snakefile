def get_genome_size_from_fai(fai_file):
    genome_size = 0
    with open(fai_file, "r") as f:
        for line in f:
            if line.strip():
                genome_size += int(line.split("\t")[1])
    return genome_size


def read_list_file(file):
    with open(file, 'r') as f:
        lines = f.readlines()
        lines = [line.strip() for line in lines]
    return lines

def read_tsv_file(file):
    with open(file, 'r') as f:
        lines = f.readlines()
        data = [line.strip().split('\t') for line in lines if line.strip()]
    return data

sids_reads = read_tsv_file(doc_path)
sids = [item[0] for item in sids_reads]

